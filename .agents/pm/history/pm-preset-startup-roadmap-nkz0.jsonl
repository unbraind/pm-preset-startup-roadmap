{"ts":"2026-05-27T18:46:47.910Z","author":"codex","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-preset-startup-roadmap-nkz0"},{"op":"add","path":"/metadata/title","value":"Add publish retry + provenance fallback to release workflow"},{"op":"add","path":"/metadata/description","value":"Replace the npm publish step in .github/workflows/release.yml with a resilient version that (1) skips if the version is already published, (2) retries up to 3 times with 30s sleep, and (3) falls back to publishing without --provenance after persistent registry 404s. Permanent fix for the 2026-05-27 npm E404 outage that left all 19 packages tagged in git but unpublished on npm."},{"op":"add","path":"/metadata/type","value":"Task"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":["ci","release"]},{"op":"add","path":"/metadata/created_at","value":"2026-05-27T18:46:47.910Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-05-27T18:46:47.910Z"},{"op":"add","path":"/metadata/author","value":"codex"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"6ff6ca216e0ba450cbc9b4b30301ddff4c81e09f69ad19b932dedf2b45b23c9b","message":""}
